# Resend — formulaire contact (obligatoire en local et en prod)
# Créer un compte sur https://resend.com et une clé API.

# Sans nom de domaine encore : utiliser l’expéditeur de test Resend (les mails arrivent bien à RESEND_TO)
RESEND_FROM=onboarding@resend.dev

# Quand tu auras le domaine (ex. villa-loulou.com) : le vérifier dans https://resend.com/domains puis mettre :
# RESEND_FROM=contact@villa-loulou.com

RESEND_API_KEY=
RESEND_TO=email@exemple.com
