---
import Logo from './Logo.astro';
import { getTranslations, pathForLocale, type Locale } from '../lib/i18n';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = getTranslations(locale);

const navLinks = [
  { path: '/', key: 'common.nav.home' },
  { path: '/la-villa/', key: 'common.nav.laVilla' },
  { path: '/nos-services/', key: 'common.nav.services' },
  { path: '/contact/', key: 'common.nav.contact' },
];
---
<footer class="footer">
  <div class="footer-top">
    <div class="footer-inner">
      <div class="footer-col footer-col--brand">
        <Logo variant="light" href={pathForLocale(locale, '/')} />
        <p class="footer-tagline">{t('footer.tagline')}</p>
      </div>
      <div class="footer-col footer-col--nav">
        <h3 class="footer-heading">{t('footer.navTitle')}</h3>
        <ul class="footer-links">
          {navLinks.map((link) => (
            <li><a href={pathForLocale(locale, link.path)}>{t(link.key)}</a></li>
          ))}
        </ul>
      </div>
      <div class="footer-col">
        <h3 class="footer-heading">{t('footer.contactTitle')}</h3>
        <ul class="footer-contact">
          <li>{t('footer.address')}</li>
          <li><a href="mailto:contact@villa-loulou.com">contact@villa-loulou.com</a></li>
          <li><a href="https://wa.me/212665485359" target="_blank" rel="noopener noreferrer">+212 665-485359</a></li>
        </ul>
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="footer-bottom-inner">
      <span class="footer-copy">{t('footer.copy')}</span>
      <span class="footer-credit">{t('footer.credit')} <a href="https://www.instagram.com/nextenstudio_/" rel="noopener noreferrer" target="_blank" aria-label={t('footer.creditLabel')}>Nexten Studio</a></span>
      <p class="footer-legal">
        <a href={pathForLocale(locale, '/mentions-legales/')}>{t('footer.legalMentions')}</a>
        <span class="footer-legal-sep"> · </span>
        <a href={pathForLocale(locale, '/politique-confidentialite/')}>{t('footer.legalPrivacy')}</a>
      </p>
    </div>
  </div>
</footer>

<style>
  footer.footer {
    background: #2c2520;
    color: var(--color-sand);
    margin-top: 4rem;
    margin-bottom: 0;
  }
  .footer a {
    color: inherit;
    text-decoration: none;
    transition: color var(--transition-smooth);
  }
  .footer a:hover {
    color: var(--color-gold);
  }
  .footer a:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 2px;
  }

  .footer-top {
    padding: 3rem 2rem 2rem;
  }
  .footer-inner {
    max-width: 75rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 22rem) auto auto;
    gap: 3rem 2.5rem;
    align-items: start;
    justify-content: start;
    text-align: left;
  }
  .footer-col {
    text-align: left;
  }
  .footer-col--brand {
    max-width: 22rem;
  }
  .footer-col--nav {
    margin-left: 8rem;
  }
  .footer-tagline {
    font-size: 0.9375rem;
    line-height: 1.5;
    color: rgba(232, 224, 213, 0.9);
    margin: 1rem 0 1.25rem;
  }
  .footer-heading {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(232, 224, 213, 0.85);
    margin: 0 0 1rem;
  }
  .footer-links,
  .footer-contact {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .footer-links li,
  .footer-contact li {
    margin-bottom: 0.5rem;
    font-size: 0.9375rem;
  }
  .footer-links li:last-child,
  .footer-contact li:last-child {
    margin-bottom: 0;
  }
  .footer-contact li {
    line-height: 1.5;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding: 1rem 2rem;
  }
  .footer-bottom-inner {
    max-width: 75rem;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .footer-copy,
  .footer-credit {
    font-size: 0.8125rem;
    color: rgba(232, 224, 213, 0.75);
  }
  .footer-credit a {
    color: inherit;
  }
  .footer-legal {
    font-size: 0.8125rem;
    color: rgba(232, 224, 213, 0.75);
    margin: 0;
  }
  .footer-legal a {
    color: var(--color-sand);
  }

  @media (max-width: 768px) {
    .footer-top {
      padding: 2.5rem 1.25rem 1.5rem;
    }
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      text-align: center;
    }
    .footer-col {
      text-align: center;
    }
    .footer-col--brand {
      max-width: none;
    }
    .footer-col--nav {
      margin-left: 0;
    }
    .footer-heading {
      margin-bottom: 0.75rem;
    }
    .footer-links li,
    .footer-contact li {
      margin-bottom: 0.625rem;
      font-size: 1rem;
    }
    .footer-contact li a {
      display: inline-block;
      padding: 0.25rem 0;
      min-height: 44px;
      line-height: 1.4;
    }
    .footer-bottom {
      padding: 1.25rem 1.25rem;
    }
    .footer-bottom-inner {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 1.25rem;
    }
    .footer-copy,
    .footer-credit,
    .footer-legal {
      font-size: 0.875rem;
    }
  }
</style>
