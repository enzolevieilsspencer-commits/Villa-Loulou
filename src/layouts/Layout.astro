---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { defaultLocale, locales, getTranslations, type Locale } from '../lib/i18n';
import { SITE_IMAGES } from '../lib/site-images';

interface Props {
  title: string;
  description?: string;
  locale?: Locale;
}
const { title, description = '', locale = defaultLocale } = Astro.props;
const t = getTranslations(locale);

const pathname = Astro.url.pathname;
const pathWithoutLocale = pathname.replace(/^\/(en|it|es|ar)(?=\/|$)/, '') || '/';
const baseUrl = Astro.site?.toString().replace(/\/$/, '') ?? Astro.url.origin;
const canonicalUrl = `${baseUrl}${pathname}`;
const ogImage = `${baseUrl}/og/og-image-1200x630.png`;
const ogImageSquare = `${baseUrl}/og/og-image-1200x1200.png`;
---
<!doctype html>
<html lang={locale} dir={locale === 'ar' ? 'rtl' : 'ltr'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=3" />
    <link rel="icon" href="/favicon.ico?v=3" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=3" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Villa Loulou" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Villa Loulou" />
    <meta property="og:image" content={ogImageSquare} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="1200" />
    <meta property="og:image:alt" content="Villa Loulou" />
    <meta property="og:locale" content={locale === 'fr' ? 'fr_FR' : locale === 'en' ? 'en_US' : locale === 'it' ? 'it_IT' : locale === 'es' ? 'es_ES' : 'ar_AR'} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <title>{title}</title>
    {locales.map((loc) => (
      <link
        rel="alternate"
        hreflang={loc}
        href={`${baseUrl}${loc === defaultLocale ? pathWithoutLocale : `/${loc}${pathWithoutLocale}`}`}
      />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${baseUrl}${pathWithoutLocale}`} />
  </head>
  <body data-locale={locale}>
    <a href="#main" class="skip-link">{t('common.skipLink')}</a>
    <Header locale={locale} />
    <main id="main" tabindex="-1">
      <slot />
    </main>
    <Footer locale={locale} />
    <script define:vars={{ locale, siteImages: JSON.stringify(SITE_IMAGES) }}>
      (function () {
        const COOKIE_NAME = 'villa-loulou-locale';
        const COOKIE_MAX_AGE = 365 * 24 * 60 * 60; // 1 an
        function setCookie(value) {
          document.cookie = COOKIE_NAME + '=' + encodeURIComponent(value) + '; path=/; max-age=' + COOKIE_MAX_AGE + '; SameSite=Lax';
        }
        setCookie(locale);

        // Préchargement des images du site en arrière-plan pour une navigation fluide
        function preloadImages() {
          let urls = [];
          try { urls = JSON.parse(siteImages); } catch (e) { return; }
          const base = window.location.origin;
          const concurrency = 4;
          for (let i = 0; i < urls.length; i += concurrency) {
            (function (slice) {
              setTimeout(function () {
                for (let j = 0; j < slice.length; j++) {
                  const img = new Image();
                  img.src = base + slice[j];
                }
              }, (i / concurrency) * 80);
            })(urls.slice(i, i + concurrency));
          }
        }
        if (document.readyState === 'complete') {
          setTimeout(preloadImages, 100);
        } else {
          window.addEventListener('load', function () { setTimeout(preloadImages, 100); });
        }
      })();
    </script>
  </body>
</html>
