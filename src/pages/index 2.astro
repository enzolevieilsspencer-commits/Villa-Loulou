---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Villa Marrakech 4 Chambres | Piscine Privée & Petit Déjeuner — Proche Beldi Country Club"
  description="Villa 4 chambres à Marrakech avec piscine privée, hammam, petit déjeuner halal et vue sur l'Atlas. À 6 km de l'aéroport, 8 km de Jemaa el-Fna. Parking gratuit. Réservez dès maintenant."
>
  <!-- Schema.org LodgingBusiness -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LodgingBusiness",
    "name": "Villa Loulou",
    "address": { "@type": "PostalAddress", "addressLocality": "Marrakech", "addressCountry": "MA" },
    "priceRange": "€€€",
    "amenityFeature": [
      "Piscine extérieure chauffée", "WiFi gratuit", "Climatisation", "Hammam",
      "Parking privé gratuit", "Petit déjeuner halal", "4 chambres", "4 salles de bains",
      "Cuisine équipée", "Jardin", "Terrasse", "Navette aéroport"
    ]
  })} />

  <!-- 1. Hero plein écran -->
  <section class="hero" aria-labelledby="hero-title">
    <div class="hero-bg">
      <img
        src="/images/hero-villa-piscine.webp"
        alt="Villa Loulou à Marrakech — vue extérieure avec piscine privée et montagnes de l'Atlas"
        width="1920"
        height="1080"
        fetchpriority="high"
      />
      <span class="hero-overlay" aria-hidden="true" />
    </div>
    <div class="hero-content">
      <h1 id="hero-title" class="hero-title">Villa Marrakech — une demeure d'exception</h1>
      <p class="hero-subtitle">Piscine privée, hammam, petit déjeuner halal. À deux pas du Beldi Country Club, vivez Marrakech autrement.</p>
      <div class="hero-ctas">
        <a href="/la-villa/" class="btn btn-primary">Découvrir la villa</a>
        <a href="/contact/" class="btn btn-secondary">Nous contacter</a>
      </div>
    </div>
  </section>

  <!-- 2. Accroche courte -->
  <section class="section section--accroche" aria-labelledby="accroche-title">
    <div class="container">
      <h2 id="accroche-title" class="visually-hidden">Notre villa</h2>
      <p class="accroche-text">
        Villa Loulou vous accueille dans une propriété de caractère, entre jardins et vue sur l'Atlas. Quatre chambres, une piscine chauffée et des prestations pensées pour un séjour tout confort : petit déjeuner servi sur place, femme de ménage, et une équipe à votre écoute 24h/24.
      </p>
    </div>
  </section>

  <!-- 3. Points forts -->
  <section class="section section--points-forts" aria-labelledby="points-forts-title">
    <div class="container">
      <h2 id="points-forts-title" class="section-title">Pourquoi choisir Villa Loulou</h2>
      <ul class="points-forts-grid">
        <li class="point-fort">
          <span class="point-fort-icon" aria-hidden="true">♨</span>
          <span class="point-fort-label">Piscine chauffée</span>
        </li>
        <li class="point-fort">
          <span class="point-fort-icon" aria-hidden="true">🍳</span>
          <span class="point-fort-label">Petit déjeuner</span>
        </li>
        <li class="point-fort">
          <span class="point-fort-icon" aria-hidden="true">🏓</span>
          <span class="point-fort-label">Ping Pong</span>
        </li>
        <li class="point-fort">
          <span class="point-fort-icon" aria-hidden="true">🧹</span>
          <span class="point-fort-label">Femme de ménage</span>
        </li>
      </ul>
    </div>
  </section>

  <!-- 4. Aperçu galerie -->
  <section class="section section--galerie" aria-labelledby="galerie-title">
    <div class="container">
      <h2 id="galerie-title" class="section-title">Un aperçu de la villa</h2>
      <div class="galerie-apercu">
        <img src="/images/villa-marrakech-salon-1.webp" alt="Salon de la Villa Loulou à Marrakech" width="800" height="600" loading="lazy" />
        <img src="/images/villa-marrakech-chambre-1.webp" alt="Chambre de la Villa Loulou" width="800" height="600" loading="lazy" />
        <img src="/images/villa-marrakech-terrasse-1.webp" alt="Terrasse et jardin de la villa" width="800" height="600" loading="lazy" />
      </div>
      <p class="section-cta">
        <a href="/la-villa/" class="link-arrow">Voir toute la villa</a>
      </p>
    </div>
  </section>

  <!-- 5. Extrait Services -->
  <section class="section section--services" aria-labelledby="services-title">
    <div class="container">
      <h2 id="services-title" class="section-title">Services inclus dans votre séjour</h2>
      <p class="services-teaser">
        Petit déjeuner halal servi sur place, femme de ménage, navette aéroport sur demande. Découvrez l'ensemble des prestations pour un séjour sans souci.
      </p>
      <p class="section-cta">
        <a href="/nos-services/" class="link-arrow">Voir nos services</a>
      </p>
    </div>
  </section>

  <!-- 6. Témoignages -->
  <section class="section section--temoignages" aria-labelledby="temoignages-title">
    <div class="container">
      <h2 id="temoignages-title" class="section-title">Ils ont séjourné à Villa Loulou</h2>
      <ul class="temoignages-list">
        <li class="temoignage">
          <blockquote>
            <p>Un havre de paix. La piscine et le petit déjeuner sur la terrasse ont fait de notre séjour un moment inoubliable. À recommander sans hésiter.</p>
            <footer>— Famille M., Paris</footer>
          </blockquote>
        </li>
        <li class="temoignage">
          <blockquote>
            <p>Villa magnifique, propre et bien équipée. Proche du Beldi pour déjeuner, et à 15 min de la Médina. Parfait.</p>
            <footer>— Sophie & Thomas, Lyon</footer>
          </blockquote>
        </li>
      </ul>
    </div>
  </section>

  <!-- 7. CTA final -->
  <section class="section section--cta" aria-labelledby="cta-title">
    <div class="container container--narrow">
      <h2 id="cta-title" class="cta-title">Prêt à réserver votre séjour ?</h2>
      <p class="cta-text">Contactez-nous pour les disponibilités et tarifs.</p>
      <a href="/contact/" class="btn btn-primary btn--large">Nous contacter</a>
    </div>
  </section>
</Layout>

<style>
  .container {
    max-width: 75rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .container--narrow {
    max-width: 40rem;
    text-align: center;
  }
  .section {
    padding: 4rem 0;
  }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 400;
    color: var(--color-text-primary);
    margin: 0 0 1.5rem;
    text-align: center;
  }
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Hero */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
  }
  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: var(--color-hero-overlay);
  }
  .hero-content {
    position: relative;
    z-index: 1;
    padding: 2rem 1.5rem;
    max-width: 36rem;
  }
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 400;
    color: white;
    margin: 0 0 1rem;
    line-height: 1.2;
  }
  .hero-subtitle {
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.95);
    margin: 0 0 2rem;
    line-height: 1.5;
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    border-radius: 0.25rem;
    transition: background var(--transition-smooth), color var(--transition-smooth), border-color var(--transition-smooth);
  }
  .btn:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 2px;
  }
  .btn-primary {
    background: var(--color-terracotta);
    color: white;
    border: none;
  }
  .btn-primary:hover {
    background: var(--color-terracotta-dark);
  }
  .btn-secondary {
    background: transparent;
    color: white;
    border: 2px solid rgba(255, 255, 255, 0.7);
  }
  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.15);
    border-color: white;
  }
  .btn--large {
    padding: 1rem 2rem;
    font-size: 1.125rem;
  }

  /* Accroche */
  .accroche-text {
    font-size: 1.25rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    text-align: center;
    margin: 0;
    max-width: 42rem;
    margin-left: auto;
    margin-right: auto;
  }

  /* Points forts */
  .points-forts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .point-fort {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }
  .point-fort-icon {
    font-size: 2.5rem;
  }
  .point-fort-label {
    font-weight: 500;
    color: var(--color-text-primary);
  }

  /* Galerie aperçu */
  .galerie-apercu {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }
  .galerie-apercu img {
    width: 100%;
    height: auto;
    aspect-ratio: 4/3;
    object-fit: cover;
    border-radius: 0.25rem;
  }
  .section-cta {
    text-align: center;
    margin: 0;
  }
  .link-arrow {
    font-weight: 600;
    color: var(--color-terracotta);
    text-decoration: none;
  }
  .link-arrow:hover {
    text-decoration: underline;
  }
  .link-arrow:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 2px;
  }

  /* Services teaser */
  .services-teaser {
    text-align: center;
    color: var(--color-text-secondary);
    max-width: 36rem;
    margin: 0 auto 1.5rem;
    line-height: 1.6;
  }

  /* Témoignages */
  .temoignages-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 2rem;
    max-width: 40rem;
    margin: 0 auto;
  }
  .temoignage blockquote {
    margin: 0;
    padding: 1.5rem;
    background: white;
    border-radius: 0.25rem;
    box-shadow: 0 2px 12px rgba(44, 37, 32, 0.06);
  }
  .temoignage p {
    font-style: italic;
    color: var(--color-text-primary);
    margin: 0 0 0.75rem;
    line-height: 1.6;
  }
  .temoignage footer {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
  }

  /* CTA final */
  .section--cta {
    background: var(--color-text-primary);
    color: var(--color-sand);
  }
  .cta-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 400;
    margin: 0 0 0.5rem;
    color: white;
  }
  .cta-text {
    margin: 0 0 1.5rem;
    color: var(--color-sand);
  }
  .section--cta .btn-primary {
    background: var(--color-terracotta);
  }
  .section--cta .btn-primary:hover {
    background: var(--color-terracotta-dark);
  }
</style>
