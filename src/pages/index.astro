---
import Layout from '../layouts/Layout.astro';
import { getTranslations, pathForLocale } from '../lib/i18n';
import IconPool from '~icons/mdi/pool';
import IconSilverwareForkKnife from '~icons/mdi/silverware-fork-knife';
import IconTableTennis from '~icons/mdi/table-tennis';
import IconBroom from '~icons/mdi/broom';

const locale = 'fr';
const t = getTranslations(locale);
const labelVoirPlus = t('home.temoignagesVoirPlus');
const labelVoirMoins = t('home.temoignagesVoirMoins');
---

<Layout
  locale={locale}
  title={t('home.metaTitle')}
  description={t('home.metaDescription')}
>
  <!-- Schema.org LodgingBusiness -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LodgingBusiness",
    "name": "Villa Loulou",
    "address": { "@type": "PostalAddress", "addressLocality": "Marrakech", "addressCountry": "MA" },
    "priceRange": "€€€",
    "amenityFeature": [
      "Piscine extérieure chauffée", "WiFi gratuit", "Climatisation", "Hammam",
      "Parking privé gratuit", "Petit déjeuner halal", "4 chambres", "4 salles de bains",
      "Cuisine équipée", "Jardin", "Terrasse", "Navette aéroport"
    ]
  })} />

  <!-- 1. Hero plein écran -->
  <section class="hero" aria-labelledby="hero-title">
    <div class="hero-bg">
      <img
        src="/images/Hero-section.jpg"
        alt="Villa Loulou à Marrakech — vue extérieure avec piscine privée et jardin"
        width="1920"
        height="1080"
        fetchpriority="high"
      />
      <span class="hero-overlay" aria-hidden="true" />
    </div>
    <div class="hero-content">
      <h1 id="hero-title" class="hero-title">{t('home.heroTitle')}</h1>
      <h2 class="hero-subtitle">{t('home.heroSubtitle')}</h2>
      <div class="hero-ctas">
        <a href={pathForLocale(locale, '/la-villa/')} class="btn btn-primary">{t('home.heroCtaDiscover')}</a>
        <a href={pathForLocale(locale, '/contact/')} class="btn btn-secondary">{t('home.heroCtaContact')}</a>
      </div>
    </div>
  </section>

  <!-- 2. Accroche (image gauche, texte droite) -->
  <section class="section section--accroche" aria-labelledby="accroche-title">
    <div class="container">
      <div class="accroche-layout">
        <div class="accroche-image" data-video-wrap>
          <video
            class="accroche-media"
            src="/video/WhatsApp%20Video%202026-03-18%20at%2011.32.23.mp4"
            muted
            autoplay
            playsinline
            loop
            preload="metadata"
            aria-label="Vidéo : aperçu de la Villa Loulou"
            data-accroche-video
          />
          <button type="button" class="video-icon-btn video-fullscreen-btn" aria-label="Voir la vidéo en plein écran" data-video-fullscreen>
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
              <path d="M9.00002 3.99998H4.00004L4 9M20 8.99999V4L15 3.99997M15 20H20L20 15M4 15L4 20L9.00002 20" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </button>
        </div>
        <div class="accroche-content">
          <h2 id="accroche-title" class="visually-hidden">{t('home.accrocheTitle')}</h2>
          <p class="accroche-text">
            {t('home.accrocheText')}
          </p>
        </div>
      </div>
    </div>
  </section>

  <div class="video-overlay" hidden data-video-overlay aria-hidden="true">
    <video
      class="video-overlay__video"
      src="/video/WhatsApp%20Video%202026-03-18%20at%2011.32.23.mp4"
      controls
      playsinline
      preload="metadata"
      data-overlay-video
    ></video>
    <button type="button" class="video-overlay__close" aria-label="Fermer la vidéo" data-video-overlay-close>
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path d="M18.3 5.71 12 12l6.3 6.29-1.41 1.42L10.59 13.4 4.29 19.71 2.88 18.29 9.17 12 2.88 5.71 4.29 4.29l6.3 6.3 6.29-6.3 1.42 1.42Z"/>
      </svg>
    </button>
  </div>

  <!-- 3. Points forts -->
  <section class="section section--points-forts" aria-labelledby="points-forts-title">
    <div class="container">
      <h2 id="points-forts-title" class="section-title">{t('home.pointsFortsTitle')}</h2>
      <ul class="points-forts-grid">
        <li class="point-fort rounded-xl">
          <span class="point-fort-icon" aria-hidden="true"><IconPool /></span>
          <span class="point-fort-label">{t('home.pointsFortsPool')}</span>
        </li>
        <li class="point-fort rounded-xl">
          <span class="point-fort-icon" aria-hidden="true"><IconSilverwareForkKnife /></span>
          <span class="point-fort-label">{t('home.pointsFortsBreakfast')}</span>
        </li>
        <li class="point-fort rounded-xl">
          <span class="point-fort-icon" aria-hidden="true"><IconTableTennis /></span>
          <span class="point-fort-label">{t('home.pointsFortsPingpong')}</span>
        </li>
        <li class="point-fort rounded-xl">
          <span class="point-fort-icon" aria-hidden="true"><IconBroom /></span>
          <span class="point-fort-label">{t('home.pointsFortsMaid')}</span>
        </li>
      </ul>
      <p class="points-forts-cta">
        <a href={pathForLocale(locale, '/nos-services/')} class="points-forts-link">{t('home.pointsFortsCta')}</a>
      </p>
    </div>
  </section>

  <!-- 4. Aperçu galerie -->
  <section class="section section--galerie" aria-labelledby="galerie-title">
    <div class="container container--galerie">
      <h2 id="galerie-title" class="section-title">{t('home.galerieTitle')}</h2>
      <div class="galerie-apercu">
        <img src="/images/hammam.jpg" alt="Hammam traditionnel de la Villa Loulou à Marrakech" width="800" height="600" loading="lazy" />
        <img src="/images/Piscine2.jpg" alt="Piscine et transats de la Villa Loulou" width="800" height="600" loading="lazy" />
        <img src="/images/Salon1.jpg" alt="Salon de la Villa Loulou à Marrakech" width="800" height="600" loading="lazy" />
      </div>
      <p class="section-cta">
        <a href={pathForLocale(locale, '/la-villa/')} class="link-arrow">{t('home.galerieCta')}</a>
      </p>
    </div>
  </section>

  <!-- 5. Témoignages -->
  <section class="section section--temoignages" aria-labelledby="temoignages-title">
    <div class="container">
      <h2 id="temoignages-title" class="section-title">{t('home.temoignagesTitle')}</h2>
      <ul class="temoignages-list">
        <li class="temoignage temoignage--expandable" data-expandable>
          <blockquote>
            <p class="temoignage__text">
              {t('home.temoignage1Text')}
            </p>
            <button type="button" class="temoignage__voir-plus" aria-expanded="false" data-more={labelVoirPlus} data-less={labelVoirMoins}>{labelVoirPlus}</button>
            <footer>{t('home.temoignage1Footer')}</footer>
          </blockquote>
        </li>
        <li class="temoignage temoignage--expandable" data-expandable>
          <blockquote>
            <p class="temoignage__text">
              <strong>{t('home.temoignage2Intro')}</strong> {t('home.temoignage2Text')}
            </p>
            <button type="button" class="temoignage__voir-plus" aria-expanded="false" data-more={labelVoirPlus} data-less={labelVoirMoins}>{labelVoirPlus}</button>
            <footer>{t('home.temoignage2Footer')}</footer>
          </blockquote>
        </li>
      </ul>
    </div>
  </section>

  <!-- 6. CTA final -->
  <section class="section section--cta" aria-labelledby="cta-title">
    <div class="container container--narrow cta-final">
      <h2 id="cta-title" class="cta-final__title">{t('home.ctaTitle')}</h2>
      <p class="cta-final__text">{t('home.ctaText')}</p>
      <a href={pathForLocale(locale, '/contact/')} class="btn btn-primary btn--large cta-final__btn">{t('home.ctaBtn')}</a>
    </div>
  </section>

  <script>
    document.querySelectorAll('[data-expandable]').forEach(function (el) {
      var btn = el.querySelector('.temoignage__voir-plus');
      if (!btn) return;
      var more = btn.getAttribute('data-more') || 'Voir plus…';
      var less = btn.getAttribute('data-less') || 'Voir moins';
      btn.addEventListener('click', function () {
        var expanded = el.classList.toggle('is-expanded');
        btn.setAttribute('aria-expanded', expanded);
        btn.textContent = expanded ? less : more;
      });
    });
  </script>
  <script>
    (function () {
      var btn = document.querySelector('[data-video-fullscreen]');
      var exitBtn = document.querySelector('[data-video-exit]');
      var video = document.querySelector('[data-accroche-video]');
      var wrap = document.querySelector('[data-video-wrap]');
      if (!btn || !video) return;

      function isFullscreen() {
        return !!(document.fullscreenElement || document.webkitFullscreenElement);
      }

      function syncButtons() {
        if (!exitBtn) return;
        exitBtn.hidden = !isFullscreen();
      }

      function enterFullscreen() {
        // iOS Safari: plein écran natif vidéo
        if (typeof video.webkitEnterFullscreen === 'function') {
          video.webkitEnterFullscreen();
          return;
        }
        // Standard Fullscreen API
        var target = wrap || video;
        if (target.requestFullscreen) {
          target.requestFullscreen();
          return;
        }
        // Safari older prefix
        if (target.webkitRequestFullscreen) {
          target.webkitRequestFullscreen();
        }
      }

      function exitFullscreen() {
        if (document.exitFullscreen) {
          document.exitFullscreen();
          return;
        }
        if (document.webkitExitFullscreen) {
          document.webkitExitFullscreen();
        }
      }

      btn.addEventListener('click', function () {
        // Plein écran "type YouTube" (overlay) pour éviter les bandes/bords selon devices.
        var overlay = document.querySelector('[data-video-overlay]');
        var overlayVideo = document.querySelector('[data-overlay-video]');
        var closeBtn = document.querySelector('[data-video-overlay-close]');
        if (!overlay || !overlayVideo) {
          // fallback
          try { if (video.paused) video.play(); } catch (e) {}
          enterFullscreen();
          return;
        }

        try { overlayVideo.currentTime = video.currentTime || 0; } catch (e) {}
        try { overlayVideo.playbackRate = video.playbackRate || 1; } catch (e) {}

        overlay.hidden = false;
        document.documentElement.classList.add('is-video-overlay-open');
        try { overlayVideo.play(); } catch (e) {}
        try { if (closeBtn) closeBtn.focus(); } catch (e) {}
      });

      // Overlay close logic
      (function () {
        var overlay = document.querySelector('[data-video-overlay]');
        var overlayVideo = document.querySelector('[data-overlay-video]');
        var closeBtn = document.querySelector('[data-video-overlay-close]');
        if (!overlay || !overlayVideo || !closeBtn) return;

        function closeOverlay() {
          overlay.hidden = true;
          document.documentElement.classList.remove('is-video-overlay-open');
          try { overlayVideo.pause(); } catch (e) {}
        }

        closeBtn.addEventListener('click', closeOverlay);
        overlay.addEventListener('click', function (e) {
          if (e.target === overlay) closeOverlay();
        });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && !overlay.hidden) closeOverlay();
        });
      })();
    })();
  </script>
</Layout>

<style>
  .container {
    max-width: 75rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .container--narrow {
    max-width: 40rem;
    text-align: center;
  }
  .container--galerie {
    max-width: 90rem;
  }
  .section {
    padding: 4rem 0;
  }
  @media (max-width: 768px) {
    .container {
      padding-left: 1rem;
      padding-right: 1rem;
    }
    .section {
      padding: 2.5rem 0;
    }
    .section-title {
      font-size: 1.5rem;
      margin-bottom: 1.5rem;
    }
    .section--points-forts .section-title {
      font-size: 1.3rem;
      letter-spacing: -0.01em;
    }
  }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 400;
    color: var(--color-text-primary);
    margin: -0.5rem 0 1.25rem;
    text-align: center;
  }
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Hero */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }
  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: translateZ(0);
    backface-visibility: hidden;
  }
  @media (max-width: 768px) {
    .hero {
      min-height: 100vh;
      min-height: 100svh;
    }
    .hero-bg {
      overflow: hidden;
    }
    .hero-bg img {
      transform: none;
    }
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.25),
      rgba(0, 0, 0, 0.45)
    );
  }
  .hero-content {
    position: relative;
    z-index: 1;
    padding: 2.5rem 2rem;
    max-width: 38rem;
    margin-top: -5rem;
  }
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    font-weight: 400;
    color: white;
    margin: 0 0 0.75rem;
    line-height: 1.15;
  }
  .hero-subtitle {
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.95);
    margin: 0 0 1.5rem;
    line-height: 1.5;
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    min-height: 48px;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    border-radius: var(--radius-full);
    transition: background var(--transition-smooth), color var(--transition-smooth), border-color var(--transition-smooth);
  }
  .btn:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 2px;
  }
  .btn-primary {
    background: var(--color-terracotta);
    color: white;
    border: none;
  }
  .btn-primary:hover {
    background: var(--color-terracotta-dark);
  }
  .btn-secondary {
    background: transparent;
    color: white;
    border: 2px solid rgba(255, 255, 255, 0.7);
  }
  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.15);
    border-color: white;
  }
  .btn--large {
    padding: 1rem 2rem;
    font-size: 1.125rem;
  }

  /* Accroche (image gauche, texte droite) */
  .accroche-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }
  .accroche-image {
    width: 100%;
    position: relative;
  }
  .accroche-media {
    width: 100%;
    height: auto;
    aspect-ratio: 3/2;
    object-fit: cover;
    border-radius: var(--radius-xl);
    display: block;
  }
  @media (min-width: 769px) {
    .accroche-media {
      aspect-ratio: 4/3;
    }
  }
  .video-icon-btn {
    position: absolute;
    z-index: 2;
    border: 0;
    border-radius: 999px;
    width: 42px;
    height: 42px;
    display: grid;
    place-items: center;
    padding: 0;
    color: #fff;
    background: rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    cursor: pointer;
    transition: background var(--transition-smooth), transform var(--transition-smooth);
  }
  .video-icon-btn svg {
    width: 22px;
    height: 22px;
    display: block;
    fill: currentColor;
  }
  .video-icon-btn:hover {
    background: rgba(0, 0, 0, 0.65);
    transform: translateY(-1px);
  }
  .video-icon-btn:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 2px;
  }

  .video-fullscreen-btn {
    right: 0.75rem;
    bottom: 0.75rem;
  }

  /* Plein écran "type YouTube" (overlay) */
  .video-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.92);
    display: grid;
    place-items: center;
    padding: 1rem;
  }
  .video-overlay[hidden] {
    display: none;
  }
  .video-overlay__video {
    width: min(100%, 1200px);
    height: min(100%, 80vh);
    max-height: 100%;
    aspect-ratio: 16/9;
    object-fit: contain;
    background: #000;
    border-radius: 12px;
    display: block;
  }
  @media (max-width: 768px) {
    .video-overlay {
      padding: 0;
    }
    .video-overlay__video {
      width: 100%;
      height: 100%;
      max-height: 100%;
      border-radius: 0;
      aspect-ratio: auto;
    }
  }
  .video-overlay__close {
    position: fixed;
    right: 0.75rem;
    top: 0.75rem;
    width: 44px;
    height: 44px;
    border: 0;
    border-radius: 999px;
    display: grid;
    place-items: center;
    padding: 0;
    color: #fff;
    background: rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    cursor: pointer;
  }
  .video-overlay__close svg {
    width: 22px;
    height: 22px;
    fill: currentColor;
    display: block;
  }
  .video-overlay__close:hover {
    background: rgba(0, 0, 0, 0.65);
  }
  .video-overlay__close:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 2px;
  }
  html.is-video-overlay-open,
  html.is-video-overlay-open body {
    height: 100%;
    overflow: hidden;
  }
  .accroche-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 46rem;
    margin: 0;
  }
  .accroche-text {
    font-size: 1.25rem;
    line-height: 1.7;
    color: var(--color-text-primary);
    text-align: left;
    margin: 0;
  }
  @media (max-width: 768px) {
    .hero-content {
      padding: 1.5rem 1rem;
      margin-top: 0;
    }
    .hero-title {
      font-size: 1.75rem;
    }
    .hero-subtitle {
      font-size: 1rem;
      margin-bottom: 1.25rem;
    }
    .hero-ctas {
      flex-direction: column;
      width: 100%;
      max-width: 280px;
      margin: 0 auto;
    }
    .hero-ctas .btn {
      width: 100%;
    }
    .accroche-layout {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      align-items: start;
    }
    .accroche-content {
      margin: 0 auto;
    }
    .accroche-media {
      aspect-ratio: 3/2;
    }
    .accroche-text {
      text-align: center;
      font-size: 1.0625rem;
    }
  }

  /* Points forts */
  .section--points-forts .section-title {
    margin-bottom: 3.5rem;
  }
  .points-forts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  @media (max-width: 768px) {
    .section--points-forts .section-title {
      margin-bottom: 2rem;
    }
    .points-forts-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }
    .point-fort {
      padding: 1.25rem 0.75rem;
      min-height: 100px;
    }
    .point-fort-icon :global(svg) {
      width: 2.25rem;
      height: 2.25rem;
    }
    .point-fort-label {
      font-size: 0.9375rem;
    }
  }
  .point-fort {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1.5rem 1rem;
    background: white;
    box-shadow: 0 4px 20px rgba(44, 37, 32, 0.08);
    transition: transform var(--transition-smooth), box-shadow var(--transition-smooth);
  }
  .point-fort:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(44, 37, 32, 0.12);
  }
  .point-fort-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-terracotta);
  }
  .point-fort-icon :global(svg) {
    width: 2.5rem;
    height: 2.5rem;
  }
  .point-fort-label {
    font-weight: 500;
    color: var(--color-text-primary);
  }
  .points-forts-cta {
    text-align: center;
    margin: 2rem 0 0;
  }
  .points-forts-link {
    font-weight: 500;
    color: var(--color-terracotta);
    text-decoration: none;
    transition: color var(--transition-smooth);
  }
  .points-forts-link:hover {
    color: var(--color-terracotta-dark);
    text-decoration: underline;
  }

  /* Galerie aperçu */
  .galerie-apercu {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-bottom: 2rem;
  }
  @media (max-width: 900px) {
    .galerie-apercu {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
  .galerie-apercu img {
    width: 100%;
    height: auto;
    aspect-ratio: 4/3;
    object-fit: cover;
    border-radius: var(--radius-xl);
    transition: transform var(--transition-smooth);
  }
  .galerie-apercu img:hover {
    transform: scale(1.02);
  }
  .section-cta {
    text-align: center;
    margin: 0;
  }
  .link-arrow {
    font-weight: 600;
    color: var(--color-terracotta);
    text-decoration: none;
  }
  .link-arrow:hover {
    text-decoration: underline;
  }
  .link-arrow:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 2px;
  }

  /* Témoignages */
