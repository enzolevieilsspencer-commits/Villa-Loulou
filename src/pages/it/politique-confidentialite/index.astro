---
import Layout from '../../../layouts/Layout.astro';
import { getTranslations, pathForLocale } from '../../../lib/i18n';

const locale = 'it';
const t = getTranslations(locale);
const mentionsUrl = pathForLocale(locale, '/mentions-legales/');
---
<Layout
  locale={locale}
  title={t('legal.privacyMetaTitle')}
  description={t('legal.privacyMetaDescription')}
>
  <section class="section">
    <div class="container container--narrow legal-prose">
      <h1 class="page-title">{t('legal.privacyH1')}</h1>
      <p class="legal-intro">{t('legal.privacyIntro')}</p>

      <h2 id="responsable">{t('legal.privacyResponsableH2')}</h2>
      <p>{t('legal.privacyResponsableP1')}<a href={mentionsUrl}>{t('legal.mentionsTitle')}</a>{t('legal.privacyResponsableP2')}</p>

      <h2 id="donnees-collectees">{t('legal.privacyDonneesH2')}</h2>
      <p>{t('legal.privacyDonneesP')}</p>

      <h2 id="finalite">{t('legal.privacyFinaliteH2')}</h2>
      <p>{t('legal.privacyFinaliteP')}</p>

      <h2 id="duree">{t('legal.privacyDureeH2')}</h2>
      <p>{t('legal.privacyDureeP')}</p>

      <h2 id="destinataires">{t('legal.privacyDestinatairesH2')}</h2>
      <p>{t('legal.privacyDestinatairesP')}</p>

      <h2 id="droits">{t('legal.privacyDroitsH2')}</h2>
      <p>{t('legal.privacyDroitsP1')}<a href={mentionsUrl}>{t('legal.mentionsTitle')}</a>{t('legal.privacyDroitsP2')}</p>

      <h2 id="securite">{t('legal.privacySecuriteH2')}</h2>
      <p>{t('legal.privacySecuriteP')}</p>

      <h2 id="modifications">{t('legal.privacyModificationsH2')}</h2>
      <p>{t('legal.privacyModificationsP')}</p>
      <p class="legal-updated">{t('legal.privacyLastUpdate')}</p>
    </div>
  </section>
</Layout>

<style>
  .container { max-width: 75rem; margin: 0 auto; padding: 0 1.5rem; }
  .container--narrow { max-width: 40rem; }
  .section { padding: 4rem 0; }
  .page-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 1.75rem);
    font-weight: 400;
    margin: 0 0 1.5rem;
    color: var(--color-text-primary);
  }
  .legal-prose h2 {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 2rem 0 0.75rem;
    scroll-margin-top: 2rem;
  }
  .legal-prose h2:first-of-type { margin-top: 0; }
  .legal-prose p {
    margin: 0 0 1rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    font-size: 0.9375rem;
  }
  .legal-prose a {
    color: var(--color-terracotta);
    text-decoration: underline;
  }
  .legal-prose a:hover {
    color: var(--color-terracotta-dark);
  }
  .legal-intro { margin-bottom: 1.5rem; }
  .legal-updated {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    font-style: italic;
  }
</style>
