---
import Layout from '../../layouts/Layout.astro';
import { getTranslations, pathForLocale } from '../../lib/i18n';
import 'flatpickr/dist/flatpickr.min.css';
import 'leaflet/dist/leaflet.css';

const locale = 'ar';
const t = getTranslations(locale);
const privacyUrl = pathForLocale(locale, '/politique-confidentialite/');
---

<Layout
  locale={locale}
  title={t('contact.metaTitle')}
  description={t('contact.metaDescription')}
>
  <!-- 1. En-tête -->
  <section class="section section--header" aria-labelledby="contact-title">
    <div class="container container--narrow">
      <h1 id="contact-title" class="page-title">{t('contact.pageTitle')}</h1>
      <p class="page-subtitle">{t('contact.pageSubtitle')}</p>
    </div>
  </section>

  <!-- 2. Formulaire + Infos + Carte -->
  <section class="section section--contact" aria-labelledby="form-title">
    <div class="container container--contact">
      <div class="contact-form-wrapper rounded-2xl">
        <h2 id="form-title" class="visually-hidden">{t('contact.formTitle')}</h2>
        <form id="contact-form" class="contact-form" action="/api/contact" method="post" aria-label={t('contact.formTitle')}>
          <div class="form-group">
            <label for="nom">{t('contact.formLabelName')} <span aria-hidden="true">{t('contact.formRequired')}</span></label>
            <input type="text" id="nom" name="nom" required autocomplete="name" />
          </div>
          <div class="form-group">
            <label for="email">{t('contact.formLabelEmail')} <span aria-hidden="true">{t('contact.formRequired')}</span></label>
            <input type="email" id="email" name="email" required autocomplete="email" />
          </div>
          <div class="form-group">
            <label for="telephone">{t('contact.formLabelPhone')}</label>
            <input type="tel" id="telephone" name="telephone" autocomplete="tel" />
          </div>
          <div class="form-group form-group--dates">
            <label for="dates-input">{t('contact.formLabelDates')}</label>
            <div class="datepicker-wrap">
              <input type="text" id="dates-input" class="datepicker-input" placeholder="Arrivée → Départ" autocomplete="off" readonly aria-label={t('contact.formLabelDates')} />
              <span class="datepicker-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              </span>
            </div>
            <input type="hidden" id="date_arrivee" name="date_arrivee" />
            <input type="hidden" id="date_depart" name="date_depart" />
            <input type="hidden" id="dates" name="dates" />
          </div>
          <div class="form-group">
            <label for="voyageurs">{t('contact.formLabelTravelers')}</label>
            <input type="text" id="voyageurs" name="voyageurs" inputmode="numeric" pattern="[0-9]*" placeholder="Ex. 4" autocomplete="off" />
          </div>
          <div class="form-group">
            <label for="message">{t('contact.formLabelMessage')} <span aria-hidden="true">{t('contact.formRequired')}</span></label>
            <textarea id="message" name="message" rows="5" required></textarea>
          </div>
          <!-- Honeypot anti-spam -->
          <div class="form-group form-group--hp" aria-hidden="true">
            <label for="website">Site web</label>
            <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
          </div>
          <div id="form-status" class="form-status" aria-live="polite" hidden></div>
          <p class="form-privacy">
            {t('contact.formPrivacy')} <a href={privacyUrl}>{t('legal.privacyTitle')}</a>.
          </p>
          <button type="submit" class="btn btn-primary btn--submit">{t('contact.formSubmit')}</button>
        </form>
      </div>

      <aside class="contact-sidebar rounded-2xl" aria-labelledby="infos-title">
        <h2 id="infos-title" class="sidebar-title">{t('contact.sidebarTitle')}</h2>
        <ul class="contact-infos">
          <li>
            <strong>{t('contact.sidebarEmail')}</strong><br />
            <a href="mailto:contact@villa-loulou.com">contact@villa-loulou.com</a>
          </li>
          <li>
            <strong>{t('contact.sidebarPhone')}</strong><br />
            <a href="https://wa.me/212665485359" target="_blank" rel="noopener noreferrer">+212 665-485359</a>
          </li>
          <li>
            <strong>{t('contact.sidebarAddress')}</strong><br />
            Route Sans Nom RÉSIDENCE OLIVERAIE DE CHRIFIA, Marrakech, 40000, Morocco
          </li>
        </ul>
      </aside>
    </div>
    <div class="container container--map">
      <div class="map-wrapper map-wrapper--below">
        <div id="map-contact" class="map-container" aria-label={t('contact.mapAria')}></div>
      </div>
    </div>
  </section>
</Layout>

<script>
  import flatpickr from 'flatpickr';
  import { French } from 'flatpickr/dist/l10n/fr.js';

  (function initDatepicker() {
    var input = document.getElementById('dates-input');
    var dateArrivee = document.getElementById('date_arrivee');
    var dateDepart = document.getElementById('date_depart');
    var datesHidden = document.getElementById('dates');
    if (!input) return;

    var fp = flatpickr(input, {
      mode: 'range',
      locale: French,
      minDate: 'today',
      dateFormat: 'd/m/Y',
      altInput: false,
      allowInput: false,
      onChange: function (selectedDates) {
        if (selectedDates.length >= 1 && dateArrivee) {
          dateArrivee.value = selectedDates[0] ? fp.formatDate(selectedDates[0], 'Y-m-d') : '';
        }
        if (selectedDates.length === 2 && dateDepart) {
          dateDepart.value = fp.formatDate(selectedDates[1], 'Y-m-d');
        } else if (dateDepart) {
          dateDepart.value = '';
        }
        if (datesHidden && selectedDates.length === 2) {
          datesHidden.value = (selectedDates[0] ? fp.formatDate(selectedDates[0], 'd/m/Y') : '') + ' – ' + (selectedDates[1] ? fp.formatDate(selectedDates[1], 'd/m/Y') : '');
        }
      },
    });
  })();

  const form = document.getElementById('contact-form');
  const status = document.getElementById('form-status');
  if (form && status) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      status.hidden = false;
      status.textContent = 'Envoi en cours…';
      status.className = 'form-status form-status--pending';
      try {
        const formData = new FormData(form);
        const res = await fetch(form.getAttribute('action') ?? '', {
          method: 'POST',
          body: formData,
        });
        const data = await res.json().catch(() => ({}));
        if (res.ok && data.success) {
          status.textContent = 'Message envoyé. Nous vous recontacterons rapidement.';
          status.className = 'form-status form-status--success';
          form.reset();
        } else {
          status.textContent = 'Une erreur est survenue. Veuillez réessayer ou nous contacter par email.';
          status.className = 'form-status form-status--error';
        }
      } catch {
        status.textContent = 'Une erreur est survenue. Veuillez réessayer ou nous contacter par email.';
        status.className = 'form-status form-status--error';
      }
    });
  }
</script>

<style>
  .container {
    max-width: 75rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .container--narrow {
    max-width: 40rem;
    text-align: center;
  }
  .section {
    padding: 4rem 0;
  }
  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 400;
    color: var(--color-text-primary);
    margin: 0 0 0.5rem;
  }
  .page-subtitle {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.5;
  }
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .container--contact {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 3rem;
    align-items: start;
  }
  @media (max-width: 768px) {
    .container {
      padding-left: 1rem;
      padding-right: 1rem;
    }
    .section {
      padding: 2.5rem 0;
    }
    .section--header {
      padding-top: 1.5rem;
    }
    .container--contact {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .contact-form-wrapper {
      padding: 1.25rem 1rem;
    }
    .contact-sidebar {
      padding: 1.25rem 1rem;
    }
    .container--map {
      margin-top: 2rem;
    }
    .map-container {
      height: 280px;
    }
    .form-group input,
    .form-group textarea {
      font-size: 16px; /* évite le zoom auto sur iOS */
      min-height: 48px;
    }
    .form-group textarea {
      min-height: 120px;
    }
    .btn--submit {
      min-height: 48px;
      width: 100%;
    }
  }

  .contact-form-wrapper {
    padding: 2rem;
    background: white;
    box-shadow: 0 4px 20px rgba(44, 37, 32, 0.08);
    transition: box-shadow var(--transition-smooth);
  }
  .contact-form-wrapper:hover {
    box-shadow: 0 12px 32px rgba(44, 37, 32, 0.12);
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .form-group--hp {
    position: absolute;
    left: -9999px;
  }
  .datepicker-wrap {
    position: relative;
    display: block;
  }
  .datepicker-input {
    width: 100%;
    padding-right: 2.75rem;
  }
  .datepicker-icon {
    position: absolute;
    right: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: var(--color-text-secondary);
  }
  /* Thème moderne Flatpickr (orange / terracotta) — :global car le calendrier est injecté dans body */
  :global(.flatpickr-calendar) {
    border-radius: 16px;
    box-shadow: 0 12px 40px rgba(44, 37, 32, 0.15);
    border: none;
    overflow: hidden;
  }
  :global(.flatpickr-months .flatpickr-month) {
    background: var(--color-terracotta);
    color: white;
  }
  :global(.flatpickr-current-month .flatpickr-monthDropdown-months),
  :global(.flatpickr-current-month .numInputWrapper span.arrowUp:after),
  :global(.flatpickr-current-month .numInputWrapper span.arrowDown:after) {
    border-color: rgba(255,255,255,0.9);
  }
  :global(.flatpickr-current-month input.cur-year),
  :global(.flatpickr-current-month .flatpickr-monthDropdown-months) {
    color: white;
  }
  :global(.flatpickr-weekdays span.flatpickr-weekday) {
    color: var(--color-text-secondary);
    font-weight: 600;
  }
  :global(.flatpickr-day) {
    border-radius: 10px;
  }
  :global(.flatpickr-day:hover) {
    background: rgba(191, 87, 66, 0.15);
    border-color: transparent;
  }
  :global(.flatpickr-day.selected),
  :global(.flatpickr-day.startRange),
  :global(.flatpickr-day.endRange),
  :global(.flatpickr-day.selected:hover),
  :global(.flatpickr-day.startRange:hover),
  :global(.flatpickr-day.endRange:hover) {
    background: var(--color-terracotta) !important;
    border-color: var(--color-terracotta) !important;
    color: white !important;
  }
  :global(.flatpickr-day.inRange) {
    background: rgba(184, 84, 58, 0.25) !important;
    border-color: transparent !important;
    box-shadow: none !important;
  }
  :global(.flatpickr-day.inRange:hover) {
    background: rgba(184, 84, 58, 0.35) !important;
  }
  :global(.flatpickr-day.flatpickr-disabled) {
    color: rgba(44, 37, 32, 0.3);
  }
  :global(.flatpickr-day.today) {
    border-color: transparent !important;
    box-shadow: none !important;
  }
  :global(.flatpickr-day.today:hover) {
    border-color: transparent !important;
  }
  :global(.flatpickr-months .flatpickr-prev-month:hover svg),
  :global(.flatpickr-months .flatpickr-next-month:hover svg) {
    fill: white;
  }
  :global(.flatpickr-months .flatpickr-prev-month svg),
  :global(.flatpickr-months .flatpickr-next-month svg) {
    fill: rgba(255,255,255,0.9);
  }
  :global(.flatpickr-calendar.arrowTop:before) { border-bottom-color: var(--color-terracotta); }
  :global(.flatpickr-calendar.arrowTop:after) { border-bottom-color: var(--color-terracotta); }
  :global(span.flatpickr-weekday) { color: var(--color-text-secondary); }
  .form-group label {
    font-weight: 500;
    font-size: 0.9375rem;
    color: var(--color-text-primary);
  }
  .form-group input,
  .form-group textarea {
    padding: 0.6rem 0.75rem;
    border: 1px solid rgba(44, 37, 32, 0.15);
    border-radius: var(--radius-md);
    font-family: inherit;
    font-size: 1rem;
    background: rgba(255, 255, 255, 0.9);
  }
  .form-group input:focus,
  .form-group textarea:focus {
    outline: 2px solid var(--color-terracotta);
    outline-offset: 0;
  }
  .form-status {
    font-size: 0.9375rem;
  }
  .form-status--success {
    color: #0d6b0d;
  }
  .form-status--error {
    color: var(--color-terracotta);
  }
  .form-privacy {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    margin: 0 0 1rem;
    line-height: 1.5;
  }
  .form-privacy a {
    color: var(--color-terracotta);
    text-decoration: underline;
  }
  .form-privacy a:hover {
    color: var(--color-terracotta-dark);
  }
  .contact-sidebar {
    padding: 1.5rem;
    background: white;
    box-shadow: 0 4px 20px rgba(44, 37, 32, 0.08);
    transition: box-shadow var(--transition-smooth);
  }
  .contact-sidebar:hover {
    box-shadow: 0 12px 32px rgba(44, 37, 32, 0.12);
  }
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    font-weight: 600;
    font-size: 1rem;
    border: none;
    border-radius: var(--radius-full);
    cursor: pointer;
    font-family: inherit;
  }
  .btn-primary {
    background: var(--color-terracotta);
    color: white;
  }
  .btn-primary:hover {
    background: var(--color-terracotta-dark);
  }
  .btn:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 2px;
  }

  .sidebar-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 400;
    margin: 0 0 1rem;
    color: var(--color-text-primary);
  }
  .contact-infos {
    list-style: none;
    margin: 0 0 1.5rem;
    padding: 0;
  }
  .contact-infos li {
    margin-bottom: 1rem;
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }
  .contact-infos a {
    color: var(--color-terracotta);
    text-decoration: none;
  }
  .contact-infos a:hover {
    text-decoration: underline;
  }
  .container--map {
    margin-top: 2.5rem;
  }
  .map-wrapper--below {
    width: 100%;
  }
  .map-container {
    height: 400px;
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: var(--color-sand);
  }
  :global(.map-pin) {
    border: none !important;
    background: none !important;
  }
  :global(.map-pin__svg) {
    display: block;
    width: 24px;
    height: 42px;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));
  }
</style>

<script>
  import L from 'leaflet';

  const villaCoords = [31.56706, -8.03119];

  const villaIcon = L.divIcon({
    className: 'map-pin',
    html: '<svg class="map-pin__svg" viewBox="0 0 24 42" xmlns="http://www.w3.org/2000/svg"><path d="M12 0C5.4 0 0 5.4 0 12c0 9 12 30 12 30s12-21 12-30C24 5.4 18.6 0 12 0z" fill="#b8543a" stroke="#fff" stroke-width="1.5"/></svg>',
    iconSize: [24, 42],
    iconAnchor: [12, 42],
  });

  function initMap() {
    const el = document.getElementById('map-contact');
    if (!el) return;
    const map = L.map(el, { scrollWheelZoom: true }).setView(villaCoords, 16);
    L.tileLayer('https://tiles.stadiamaps.com/tiles/osm_bright/{z}/{x}/{y}{r}.png', {
      attribution: '&copy; <a href="https://stadiamaps.com/">Stadia Maps</a> &copy; <a href="https://openmaptiles.org/">OpenMapTiles</a> &copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
      maxZoom: 20,
    }).addTo(map);
    L.marker(villaCoords, { icon: villaIcon })
      .addTo(map)
      .bindPopup('<strong>Villa Loulou</strong><br>Marrakech');
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMap);
  } else {
    initMap();
  }
</script>
