---
import Layout from '../../layouts/Layout.astro';
import { getTranslations, pathForLocale } from '../../lib/i18n';
import IconPool from '~icons/mdi/pool';
import IconSilverwareForkKnife from '~icons/mdi/silverware-fork-knife';
import IconTableTennis from '~icons/mdi/table-tennis';
import IconBroom from '~icons/mdi/broom';
import IconChefHat from '~icons/mdi/chef-hat';
import IconCart from '~icons/mdi/cart';
import IconCar from '~icons/mdi/car-side';
import IconSpa from '~icons/mdi/spa';

const locale = 'ar';
const t = getTranslations(locale);

const servicesInclus = [
  { icon: 'pool', titleKey: 'nosServices.inclusPoolTitle', descKey: 'nosServices.inclusPoolDesc' },
  { icon: 'breakfast', titleKey: 'nosServices.inclusBreakfastTitle', descKey: 'nosServices.inclusBreakfastDesc' },
  { icon: 'pingpong', titleKey: 'nosServices.inclusPingpongTitle', descKey: 'nosServices.inclusPingpongDesc' },
  { icon: 'broom', titleKey: 'nosServices.inclusMaidTitle', descKey: 'nosServices.inclusMaidDesc' },
];

const servicesSupplement = [
  { icon: 'chef', titleKey: 'nosServices.supplementChefTitle', descKey: 'nosServices.supplementChefDesc' },
  { icon: 'cart', titleKey: 'nosServices.supplementCartTitle', descKey: 'nosServices.supplementCartDesc' },
  { icon: 'navette', titleKey: 'nosServices.supplementNavetteTitle', descKey: 'nosServices.supplementNavetteDesc' },
  { icon: 'spa', titleKey: 'nosServices.supplementBienEtreTitle', descKey: 'nosServices.supplementBienEtreDesc' },
];

const iconMap = {
  pool: IconPool,
  breakfast: IconSilverwareForkKnife,
  pingpong: IconTableTennis,
  broom: IconBroom,
  chef: IconChefHat,
  cart: IconCart,
  navette: IconCar,
  spa: IconSpa,
};

const servicesPhotosInclus = [
  { src: '/images/Piscine2.jpg', alt: 'Piscine chauffée de la Villa Loulou' },
  { src: '/images/Terasse-Table-a-manger.jpg', alt: 'Petit déjeuner et repas sur la terrasse' },
  { src: '/images/Jardin1.jpg', alt: 'Jardin et détente à la villa' },
];
const experiencePhotos = [
  { src: '/images/Terasse-Salon.jpg', alt: 'Ambiance et art de vivre à la villa' },
  { src: '/images/Cuisine1.jpg', alt: 'Cuisine et repas à la villa' },
  { src: '/images/lit-piscine.jpg', alt: 'Détente au bord de la piscine' },
];

const faqItems = [
  { qKey: 'nosServices.faq1Q', aKey: 'nosServices.faq1A' },
  { qKey: 'nosServices.faq2Q', aKey: 'nosServices.faq2A' },
  { qKey: 'nosServices.faq3Q', aKey: 'nosServices.faq3A' },
  { qKey: 'nosServices.faq4Q', aKey: 'nosServices.faq4A' },
  { qKey: 'nosServices.faq5Q', aKey: 'nosServices.faq5A' },
  { qKey: 'nosServices.faq6Q', aKey: 'nosServices.faq6A' },
];
---

<Layout
  locale={locale}
  title={t('nosServices.metaTitle')}
  description={t('nosServices.metaDescription')}
>
  <!-- Schema FAQPage -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map((item) => ({
      "@type": "Question",
      "name": t(item.qKey),
      "acceptedAnswer": { "@type": "Answer", "text": t(item.aKey) }
    }))
  })} />

  <!-- 1. En-tête texte -->
  <section class="section section--header" aria-labelledby="services-main-title">
    <div class="container container--narrow">
      <h1 id="services-main-title" class="page-title">{t('nosServices.pageTitle')}</h1>
      <p class="page-subtitle">{t('nosServices.pageSubtitle')}</p>
    </div>
  </section>

  <!-- 2. Services inclus -->
  <section class="section" aria-labelledby="inclus-title">
    <div class="container">
      <h2 id="inclus-title" class="section-title">{t('nosServices.inclusTitle')}</h2>
      <ul class="services-cards">
        {servicesInclus.map((s) => {
          const IconComponent = iconMap[s.icon];
          return (
            <li class="service-card rounded-xl">
              <span class="service-card-icon" aria-hidden="true">{IconComponent && <IconComponent />}</span>
              <h3 class="service-card-title">{t(s.titleKey)}</h3>
              <p class="service-card-desc">{t(s.descKey)}</p>
            </li>
          );
        })}
      </ul>
      <div class="services-images">
        {servicesPhotosInclus.map((photo) => (
          <img src={photo.src} alt={photo.alt} width="800" height="600" loading="lazy" />
        ))}
      </div>
    </div>
  </section>

  <!-- 3. Services en supplément -->
  <section class="section section--supplement" aria-labelledby="supplement-title">
    <div class="container">
      <h2 id="supplement-title" class="section-title">{t('nosServices.supplementTitle')}</h2>
      <ul class="services-cards services-cards--supplement">
        {servicesSupplement.map((s) => {
          const IconComponent = iconMap[s.icon];
          return (
            <li class="service-card rounded-xl">
              <span class="service-card-icon" aria-hidden="true">{IconComponent && <IconComponent />}</span>
              <h3 class="service-card-title">{t(s.titleKey)}</h3>
              <p class="service-card-desc">{t(s.descKey)}</p>
            </li>
          );
        })}
      </ul>
    </div>
  </section>

  <!-- 4. L'expérience -->
  <section class="section section--experience" aria-labelledby="experience-title">
    <div class="container">
      <h2 id="experience-title" class="section-title">{t('nosServices.experienceTitle')}</h2>
      <div class="experience-content">
        <img src={experiencePhotos[0].src} alt={experiencePhotos[0].alt} width="1200" height="800" loading="lazy" class="experience-img" />
        <p class="experience-text">
          {t('nosServices.experienceText')}
        </p>
      </div>
    </div>
  </section>

  <!-- 5. FAQ -->
  <section class="section section--faq" aria-labelledby="faq-title">
    <div class="container container--narrow">
      <h2 id="faq-title" class="section-title">{t('nosServices.faqTitle')}</h2>
      <dl class="faq-list">
        {faqItems.map((item) => (
          <div class="faq-item">
            <dt class="faq-question">{t(item.qKey)}</dt>
            <dd class="faq-answer">{t(item.aKey)}</dd>
          </div>
        ))}
      </dl>
      <p class="section-cta">
        <a href={pathForLocale(locale, '/contact/')} class="btn btn-primary">{t('nosServices.ctaContact')}</a>
      </p>
    </div>
  </section>
</Layout>

<style>
  .container {
    max-width: 75rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .container--narrow {
    max-width: 40rem;
    text-align: center;
  }
  .section {
    padding: 4rem 0;
  }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 400;
    color: var(--color-text-primary);
    margin: 0 0 1.5rem;
    text-align: center;
  }
  @media (max-width: 768px) {
    .container {
      padding-left: 1rem;
      padding-right: 1rem;
    }
    .section {
      padding: 2.5rem 0;
    }
    .section-title {
      font-size: 1.5rem;
      margin-bottom: 1.25rem;
    }
    .page-title {
      font-size: 1.75rem;
    }
    .services-cards {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    .services-cards--supplement {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 0.5rem;
    }
    .section--supplement .service-card {
      padding: 0.65rem 0.35rem;
    }
    .section--supplement .service-card-title {
      font-size: 0.8125rem;
    }
    .section--supplement .service-card-desc {
      font-size: 0.6875rem;
      line-height: 1.35;
    }
    .section--supplement .service-card-icon :global(svg) {
      width: 1.5rem;
      height: 1.5rem;
    }
    .service-card {
      padding: 1.25rem 1rem;
    }
    .services-images {
      grid-template-columns: 1fr;
    }
    .faq-item {
      padding: 1rem;
    }
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 400;
    color: var(--color-text-primary);
    margin: 0 0 0.5rem;
  }
  .page-subtitle {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.5;
  }

  .services-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    list-style: none;
    margin: 0 0 2rem;
    padding: 0;
  }
  .service-card {
    padding: 1.5rem;
    background: white;
    border-radius: var(--radius-xl);
    box-shadow: 0 4px 20px rgba(44, 37, 32, 0.08);
    transition: box-shadow var(--transition-smooth);
  }
  .service-card:hover {
    box-shadow: 0 12px 32px rgba(44, 37, 32, 0.12);
  }
  .service-card-icon {
    display: block;
    margin-bottom: 0.5rem;
    color: var(--color-terracotta);
  }
  .service-card-icon :global(svg) {
    width: 2.25rem;
    height: 2.25rem;
    display: block;
  }
  .service-card-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 0 0 0.25rem;
  }
  .service-card-desc {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.5;
  }
  .services-cards--supplement {
    grid-template-columns: repeat(4, minmax(0, 1fr));
    max-width: 100%;
    width: 100%;
    margin-left: auto;
    margin-right: auto;
    gap: 1rem;
  }

  .services-images {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  .services-images img {
    width: 100%;
    height: auto;
    aspect-ratio: 4/3;
    object-fit: cover;
    border-radius: var(--radius-xl);
  }
  .section--supplement {
    background: var(--color-sand);
  }

  .experience-content {
    max-width: 50rem;
    margin: 0 auto;
  }
  .experience-img {
    width: 100%;
    height: auto;
    aspect-ratio: 3/2;
    object-fit: cover;
    border-radius: var(--radius-xl);
    margin-bottom: 1.5rem;
  }
  .experience-text {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .faq-list {
    margin: 0 0 2rem;
    padding: 0;
  }
  .faq-item {
    margin-bottom: 1rem;
    padding: 1.25rem;
    background: white;
    border-radius: var(--radius-lg);
    box-shadow: 0 4px 20px rgba(44, 37, 32, 0.08);
    transition: box-shadow var(--transition-smooth);
  }
  .faq-item:hover {
    box-shadow: 0 12px 32px rgba(44, 37, 32, 0.12);
  }
  .faq-item:last-of-type {
    margin-bottom: 0;
  }
  .faq-question {
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 0 0 0.5rem;
    font-size: 1rem;
  }
  .faq-answer {
    margin: 0;
    color: var(--color-text-secondary);
    line-height: 1.6;
    font-size: 0.9375rem;
  }
  .section-cta {
    text-align: center;
    margin: 0;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.5rem;
    background: var(--color-terracotta);
    color: white;
    font-weight: 600;
    text-decoration: none;
    border-radius: var(--radius-full);
  }
  .btn:hover {
    background: var(--color-terracotta-dark);
  }
</style>
