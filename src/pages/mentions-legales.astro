---
import Layout from '../layouts/Layout.astro';
import { getTranslations } from '../lib/i18n';

const locale = 'fr';
const t = getTranslations(locale);
---
<Layout
  locale={locale}
  title={t('legal.mentionsMetaTitle')}
  description={t('legal.mentionsMetaDescription')}
>
  <section class="section">
    <div class="container container--narrow legal-prose">
      <h1 class="page-title">{t('legal.mentionsH1')}</h1>

      <h2 id="editeur">{t('legal.mentionsEditeurH2')}</h2>
      <p>{t('legal.mentionsEditeurP')}</p>

      <h2 id="hebergeur">{t('legal.mentionsHebergeurH2')}</h2>
      <p>{t('legal.mentionsHebergeurP')}</p>

      <h2 id="propriete">{t('legal.mentionsProprieteH2')}</h2>
      <p>{t('legal.mentionsProprieteP')}</p>

      <h2 id="liens">{t('legal.mentionsLiensH2')}</h2>
      <p>{t('legal.mentionsLiensP')}</p>

      <h2 id="credits">{t('legal.mentionsCreditsH2')}</h2>
      <p>{t('legal.mentionsCreditsP')}</p>
    </div>
  </section>
</Layout>

<style>
  .container { max-width: 75rem; margin: 0 auto; padding: 0 1.5rem; }
  .container--narrow { max-width: 40rem; }
  .section { padding: 4rem 0; }
  .page-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 1.75rem);
    font-weight: 400;
    margin: 0 0 1.5rem;
    color: var(--color-text-primary);
  }
  .legal-prose h2 {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 2rem 0 0.75rem;
    scroll-margin-top: 2rem;
  }
  .legal-prose h2:first-of-type { margin-top: 0; }
  .legal-prose p {
    margin: 0 0 1rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    font-size: 0.9375rem;
  }
</style>
