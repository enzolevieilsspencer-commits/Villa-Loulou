---
import Layout from '../layouts/Layout.astro';

const servicesInclus = [
  { icon: '🏊', title: 'Piscine chauffée', desc: 'Piscine extérieure privée à disposition pendant votre séjour.' },
  { icon: '🍳', title: 'Petit déjeuner', desc: 'Petit déjeuner halal servi sur place.' },
  { icon: '🏓', title: 'Ping Pong', desc: 'Table de ping-pong pour vous détendre.' },
  { icon: '🧹', title: 'Femme de ménage', desc: 'Service de ménage inclus dans votre séjour.' },
];

const servicesSupplement = [
  { icon: '👩‍🍳', title: 'Cuisinière', desc: 'Repas cuisinés sur demande (tarif en supplément).' },
  { icon: '🛒', title: 'Courses', desc: 'Gestion des courses en supplément.' },
];

const faqItems = [
  { q: 'Le petit déjeuner est-il inclus ?', a: 'Oui, un petit déjeuner halal est servi sur place et inclus dans votre séjour.' },
  { q: 'La navette aéroport est-elle disponible ?', a: 'Oui, une navette aéroport est proposée en supplément sur demande.' },
  { q: 'Puis-je réserver un chef à la villa ?', a: 'Oui, notre cuisinière peut préparer vos repas sur demande (prestation en supplément).' },
  { q: 'La villa est-elle proche de la Médina ?', a: 'La place Jemaa el-Fna est à environ 8,3 km. Idéal pour une excursion en taxi ou voiture.' },
  { q: 'Y a-t-il une connexion WiFi ?', a: 'Oui, le WiFi gratuit est disponible dans toute la villa.' },
];
---

<Layout
  title="Nos Services — Villa avec services Marrakech | Villa Loulou"
  description="Services inclus : petit déjeuner halal, femme de ménage, piscine, ping-pong. En supplément : cuisinière, navette aéroport, courses. Découvrez l'expérience Villa Loulou."
>
  <!-- Schema FAQPage -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map((item) => ({
      "@type": "Question",
      "name": item.q,
      "acceptedAnswer": { "@type": "Answer", "text": item.a }
    }))
  })} />

  <!-- 1. En-tête texte -->
  <section class="section section--header" aria-labelledby="services-main-title">
    <div class="container container--narrow">
      <h1 id="services-main-title" class="page-title">Nos Services</h1>
      <p class="page-subtitle">Tout est pensé pour que votre séjour à la villa soit un moment de détente et de confort.</p>
    </div>
  </section>

  <!-- 2. Services inclus -->
  <section class="section" aria-labelledby="inclus-title">
    <div class="container">
      <h2 id="inclus-title" class="section-title">Inclus dans votre séjour</h2>
      <ul class="services-cards">
        {servicesInclus.map((s) => (
          <li class="service-card">
            <span class="service-card-icon" aria-hidden="true">{s.icon}</span>
            <h3 class="service-card-title">{s.title}</h3>
            <p class="service-card-desc">{s.desc}</p>
          </li>
        ))}
      </ul>
      <div class="services-images">
        <img src="/images/villa-marrakech-piscine-close.webp" alt="Piscine de la Villa Loulou" width="800" height="600" loading="lazy" />
        <img src="/images/villa-marrakech-petit-dej.webp" alt="Petit déjeuner servi à la villa" width="800" height="600" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- 3. Services en supplément -->
  <section class="section section--supplement" aria-labelledby="supplement-title">
    <div class="container">
      <h2 id="supplement-title" class="section-title">En supplément</h2>
      <ul class="services-cards services-cards--supplement">
        {servicesSupplement.map((s) => (
          <li class="service-card">
            <span class="service-card-icon" aria-hidden="true">{s.icon}</span>
            <h3 class="service-card-title">{s.title}</h3>
            <p class="service-card-desc">{s.desc}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- 4. L'expérience -->
  <section class="section section--experience" aria-labelledby="experience-title">
    <div class="container">
      <h2 id="experience-title" class="section-title">L'expérience Villa Loulou</h2>
      <div class="experience-content">
        <img src="/images/villa-marrakech-ambiance-repas.webp" alt="Ambiance et art de vivre à la villa" width="1200" height="800" loading="lazy" class="experience-img" />
        <p class="experience-text">
          Entre piscine, petit déjeuner sur la terrasse et moments de détente au jardin, Villa Loulou offre un cadre privilégié pour des vacances en famille ou entre amis. L'équipe sur place veille à votre confort et reste à votre disposition pour organiser navette aéroport, repas ou courses selon vos envies.
        </p>
      </div>
    </div>
  </section>

  <!-- 5. FAQ -->
  <section class="section section--faq" aria-labelledby="faq-title">
    <div class="container container--narrow">
      <h2 id="faq-title" class="section-title">Questions fréquentes</h2>
      <dl class="faq-list">
        {faqItems.map((item) => (
          <div class="faq-item">
            <dt class="faq-question">{item.q}</dt>
            <dd class="faq-answer">{item.a}</dd>
          </div>
        ))}
      </dl>
      <p class="section-cta">
        <a href="/contact/" class="btn btn-primary">Nous contacter</a>
      </p>
    </div>
  </section>
</Layout>

<style>
  .container {
    max-width: 75rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .container--narrow {
    max-width: 40rem;
    text-align: center;
  }
  .section {
    padding: 4rem 0;
  }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 400;
    color: var(--color-text-primary);
    margin: 0 0 1.5rem;
    text-align: center;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 400;
    color: var(--color-text-primary);
    margin: 0 0 0.5rem;
  }
  .page-subtitle {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.5;
  }

  .services-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    list-style: none;
    margin: 0 0 2rem;
    padding: 0;
  }
  .service-card {
    background: white;
    padding: 1.5rem;
    border-radius: 0.25rem;
    box-shadow: 0 2px 12px rgba(44, 37, 32, 0.06);
  }
  .service-card-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 0.5rem;
  }
  .service-card-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 0 0 0.25rem;
  }
  .service-card-desc {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.5;
  }
  .services-cards--supplement {
    max-width: 36rem;
    margin-left: auto;
    margin-right: auto;
  }

  .services-images {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  .services-images img {
    width: 100%;
    height: auto;
    aspect-ratio: 4/3;
    object-fit: cover;
    border-radius: 0.25rem;
  }

  .section--supplement {
    background: var(--color-sand);
  }

  .experience-content {
    max-width: 50rem;
    margin: 0 auto;
  }
  .experience-img {
    width: 100%;
    height: auto;
    aspect-ratio: 3/2;
    object-fit: cover;
    border-radius: 0.25rem;
    margin-bottom: 1.5rem;
  }
  .experience-text {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .faq-list {
    margin: 0 0 2rem;
    padding: 0;
  }
  .faq-item {
    margin-bottom: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(44, 37, 32, 0.1);
  }
  .faq-item:last-of-type {
    border-bottom: none;
  }
  .faq-question {
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 0 0 0.5rem;
    font-size: 1rem;
  }
  .faq-answer {
    margin: 0;
    color: var(--color-text-secondary);
    line-height: 1.6;
    font-size: 0.9375rem;
  }
  .section-cta {
    text-align: center;
    margin: 0;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.5rem;
    background: var(--color-terracotta);
    color: white;
    font-weight: 600;
    text-decoration: none;
    border-radius: 0.25rem;
  }
  .btn:hover {
    background: var(--color-terracotta-dark);
  }
</style>
