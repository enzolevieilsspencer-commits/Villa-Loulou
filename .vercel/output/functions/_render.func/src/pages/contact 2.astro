---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact — Réserver Villa Loulou Marrakech"
  description="Contactez-nous pour réserver votre séjour à la Villa Loulou à Marrakech. Disponibilités, tarifs et informations pratiques."
>
  <!-- 1. En-tête -->
  <section class="section section--header" aria-labelledby="contact-title">
    <div class="container container--narrow">
      <h1 id="contact-title" class="page-title">Contactez-nous</h1>
      <p class="page-subtitle">Une question, une demande de réservation ? Écrivez-nous, nous vous répondrons au plus vite.</p>
    </div>
  </section>

  <!-- 2. Formulaire + Infos + Carte -->
  <section class="section section--contact" aria-labelledby="form-title">
    <div class="container container--contact">
      <div class="contact-form-wrapper">
        <h2 id="form-title" class="visually-hidden">Formulaire de contact</h2>
        <form id="contact-form" class="contact-form" action="/api/contact" method="post" aria-label="Formulaire de contact">
          <div class="form-group">
            <label for="nom">Nom <span aria-hidden="true">*</span></label>
            <input type="text" id="nom" name="nom" required autocomplete="name" />
          </div>
          <div class="form-group">
            <label for="email">Email <span aria-hidden="true">*</span></label>
            <input type="email" id="email" name="email" required autocomplete="email" />
          </div>
          <div class="form-group">
            <label for="telephone">Téléphone</label>
            <input type="tel" id="telephone" name="telephone" autocomplete="tel" />
          </div>
          <div class="form-group">
            <label for="dates">Dates souhaitées</label>
            <input type="text" id="dates" name="dates" placeholder="Ex. 15-22 août 2025" autocomplete="off" />
          </div>
          <div class="form-group">
            <label for="voyageurs">Nombre de voyageurs</label>
            <input type="number" id="voyageurs" name="voyageurs" min="1" max="12" placeholder="Ex. 4" autocomplete="off" />
          </div>
          <div class="form-group">
            <label for="message">Message <span aria-hidden="true">*</span></label>
            <textarea id="message" name="message" rows="5" required></textarea>
          </div>
          <!-- Honeypot anti-spam -->
          <div class="form-group form-group--hp" aria-hidden="true">
            <label for="website">Site web</label>
            <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
          </div>
          <div id="form-status" class="form-status" aria-live="polite" hidden></div>
          <button type="submit" class="btn btn-primary btn--submit">Envoyer</button>
        </form>
      </div>

      <aside class="contact-sidebar" aria-labelledby="infos-title">
        <h2 id="infos-title" class="sidebar-title">Informations</h2>
        <ul class="contact-infos">
          <li>
            <strong>Email</strong><br />
            <a href="mailto:contact@villa-loulou.com">contact@villa-loulou.com</a>
          </li>
          <li>
            <strong>Téléphone / WhatsApp</strong><br />
            <a href="tel:+212600000000">+212 6 00 00 00 00</a>
          </li>
          <li>
            <strong>Adresse</strong><br />
            Villa Loulou — Marrakech, vue sur l'Atlas
          </li>
        </ul>
        <div class="map-wrapper">
          <iframe
            title="Localisation Villa Loulou Marrakech"
            src="https://www.openstreetmap.org/export/embed.html?bbox=-8.0%2C31.6%2C-7.9%2C31.7&layer=mapnik&marker=31.65,-7.95"
            width="100%"
            height="220"
            style="border:0; border-radius: 0.25rem;"
            loading="lazy"
          />
        </div>
        <p class="sidebar-social">
          <strong>Instagram</strong><br />
          <a href="https://instagram.com/villa-loulou" rel="noopener noreferrer" target="_blank" aria-label="Instagram Villa Loulou">@villa-loulou</a>
        </p>
      </aside>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form');
  const status = document.getElementById('form-status');
  if (form && status) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      status.hidden = false;
      status.textContent = 'Envoi en cours…';
      status.className = 'form-status form-status--pending';
      try {
        const formData = new FormData(form);
        const res = await fetch(form.getAttribute('action') ?? '', {
          method: 'POST',
          body: formData,
        });
        const data = await res.json().catch(() => ({}));
        if (res.ok && data.success) {
          status.textContent = 'Message envoyé. Nous vous recontacterons rapidement.';
          status.className = 'form-status form-status--success';
          form.reset();
        } else {
          status.textContent = 'Une erreur est survenue. Veuillez réessayer ou nous contacter par email.';
          status.className = 'form-status form-status--error';
        }
      } catch {
        status.textContent = 'Une erreur est survenue. Veuillez réessayer ou nous contacter par email.';
        status.className = 'form-status form-status--error';
      }
    });
  }
</script>

<style>
  .container {
    max-width: 75rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .container--narrow {
    max-width: 40rem;
    text-align: center;
  }
  .section {
    padding: 4rem 0;
  }
  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 400;
    color: var(--color-text-primary);
    margin: 0 0 0.5rem;
  }
  .page-subtitle {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.5;
  }
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .container--contact {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 3rem;
    align-items: start;
  }
  @media (max-width: 768px) {
    .container--contact {
      grid-template-columns: 1fr;
    }
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .form-group--hp {
    position: absolute;
    left: -9999px;
  }
  .form-group label {
    font-weight: 500;
    font-size: 0.9375rem;
    color: var(--color-text-primary);
  }
  .form-group input,
  .form-group textarea {
    padding: 0.6rem 0.75rem;
    border: 1px solid rgba(44, 37, 32, 0.2);
    border-radius: 0.25rem;
    font-family: inherit;
    font-size: 1rem;
    background: white;
  }
  .form-group input:focus,
  .form-group textarea:focus {
    outline: 2px solid var(--color-terracotta);
    outline-offset: 0;
  }
  .form-status {
    font-size: 0.9375rem;
  }
  .form-status--success {
    color: #0d6b0d;
  }
  .form-status--error {
    color: var(--color-terracotta);
  }
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    font-weight: 600;
    font-size: 1rem;
    border: none;
    border-radius: 0.25rem;
    cursor: pointer;
    font-family: inherit;
  }
  .btn-primary {
    background: var(--color-terracotta);
    color: white;
  }
  .btn-primary:hover {
    background: var(--color-terracotta-dark);
  }
  .btn:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 2px;
  }

  .sidebar-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 400;
    margin: 0 0 1rem;
    color: var(--color-text-primary);
  }
  .contact-infos {
    list-style: none;
    margin: 0 0 1.5rem;
    padding: 0;
  }
  .contact-infos li {
    margin-bottom: 1rem;
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }
  .contact-infos a {
    color: var(--color-terracotta);
    text-decoration: none;
  }
  .contact-infos a:hover {
    text-decoration: underline;
  }
  .map-wrapper {
    margin-bottom: 1.5rem;
  }
  .sidebar-social {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    margin: 0;
  }
  .sidebar-social a {
    color: var(--color-terracotta);
    text-decoration: none;
  }
</style>
